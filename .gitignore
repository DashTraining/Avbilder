# Local nested repository used for publishing the customer site to Azure DevOps.
# Keep this metadata locally, but do not publish it from the top-level repo.
/site-user/.git/
/site-user/scripts/manage-git.ps1

# Local build output for the customer site, which is published separately from the top-level repo.
# This is not needed in the top-level repo and can be large, so we ignore it here.
# The source files for the customer site are still included in the repo and published as expected, since we only ignore the build output folder.
/site-user/site/
Avbilder.code-workspace
